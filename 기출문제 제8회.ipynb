    "# 도입 전후 부호 검정\n",
    "from scipy.stats import wilcoxon\n",
    "\n",
    "statistic, p_value = wilcoxon(df['before'],df['after'])\n",
    "print(\"검정통계량 : {:.2f}\".format(statistic))\n",
    "\n",
    "# p-value 바탕으로 귀무가설 기각/채택 여부\n",
    "if p_value<0.05 : \n",
