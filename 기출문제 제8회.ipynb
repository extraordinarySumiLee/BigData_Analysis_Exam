   "source": [
    "# 훈련 데이터로 학습한 모델 테스트 (target : count) \n",
    "# 제출형식은 ID, pred (평가지표 MAE)\n",
    "train = pd.read_csv(r\"https://raw.githubusercontent.com/YoungjinBD/data/refs/heads/main/exam/8_2_train.csv\")\n",
    "test = pd.read_csv(r\"https://raw.githubusercontent.com/YoungjinBD/data/refs/heads/main/exam/8_2_test.csv\")\n",
    "\n",
    "# EDA \n",
    "display(train.head(3))\n",
    "print(f\"train data 의 길이는 {len(train)} 이고 test data 의 길이는 {len(test)} 입니다. \")\n",
    "print(\"train data 의 NaN 여부\")\n",
    "print(train.isnull().sum())\n",
    "print(\"test 데이터의 NaN 여부 \")\n",
    "print(test.isnull().sum())\n",
    "\n",
    "X_train = train.drop(['count'],axis=1)\n",
    "y_train = train['count']\n",
    "X_test = test.drop(['count'],axis=1)\n",
    "y_test = test['count']\n",
    "\n",
    "from sklearn.model_selection import train_test_split\n",
    "train_X, valid_X, train_y, valid_y = train_test_split(X_train,y_train, test_size=0.3, random_state=42)\n",
    "\n",
    "# OneHotEncoder\n",
    "from sklearn.preprocessing import OneHotEncoder\n",
    "onehot = OneHotEncoder(sparse_output=False, handle_unknown = 'ignore')\n",
    "cat_cols = train_X.select_dtypes('object').columns.to_list()\n",
    "train_X_pre = onehot.fit_transform(train_X[cat_cols])\n",
    "valid_X_pre = onehot.fit_transform(valid_X[cat_cols])\n",
    "test_X_pre = onehot.fit_transform(X_test[cat_cols])\n",
    "\n",
    "# RandomForestRegressor\n",
    "from sklearn.ensemble import RandomForestRegressor\n",
    "rf = RandomForestRegressor()\n",
    "rf.fit(train_X_pre,train_y)\n",
    "\n",
    "# 모형 성능 확인\n",
    "from sklearn.metrics import mean_absolute_error\n",
    "pred_val = rf.predict(valid_X_pre)\n",
    "print(\"Valid MAE : \",mean_absolute_error(valid_y,pred_val))\n",
    "\n",
    "# 최종 예측 \n",
    "test_pred = rf.predict(test_X_pre)\n",
    "#print(\"Valide MAE : \",mean_absolute_error(y_test,test_pred))\n",
    "# 위에꺼는 y_test 가 NaN 이라 안됨.\n",
    "#print(test_pred)\n",
